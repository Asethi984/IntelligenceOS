# =============================================================================
# IntelligenceOS — Self-Hosted Environment (compose-level)
# =============================================================================
# Copy this file to .env at the repo root:
#   cp .env.example .env
# Then fill in real values. The .env file is gitignored (real secrets only here).
# =============================================================================

# ---- Database ----
DB_NAME=intelligenc_os

# ---- Security ----
# Generate with: python -c "import secrets;print(secrets.token_urlsafe(48))"
JWT_SECRET=replace-with-64-char-random-secret
# Comma-separated explicit origins. NEVER use "*" with credentials.
CORS_ORIGINS=http://localhost:3000

# ---- LLM Gateway (external — point at your local llm-gateway) ----
# From inside Docker, host.docker.internal reaches your host machine.
OPENAI_API_BASE=http://host.docker.internal:8080/v1
# This is the gateway's GW_API_KEY — sent as the X-API-Key header on every
# chat/completions request. NOT the callback secret.
OPENAI_API_KEY=your-gateway-x-api-key
# Two-tier model mapping
LLM_MODEL_CHEAP=qwen3.5:4b
LLM_MODEL_STRONG=qwen3:14b

# ---- Email (smtp → Gmail; or resend; or none) ----
EMAIL_BACKEND=smtp
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_TLS=true
# Gmail: use your full gmail address + an App Password (16 chars).
# Create one at: https://myaccount.google.com/apppasswords
SMTP_USER=your-gmail@gmail.com
SMTP_PASS=your-16-char-app-password
SMTP_FROM=IntelligenceOS <your-gmail@gmail.com>
# Only needed if EMAIL_BACKEND=resend:
# RESEND_API_KEY=re_replace_me
# RESEND_FROM=IntelligenceOS <noreply@your-domain.com>

# ---- LLM Gateway Callback ----
# The gateway POSTs async job results here when sync calls time out (504).
# Must be reachable FROM the gateway machine.
LLM_GATEWAY_CALLBACK_URL=http://fps-dev:3000/api/ai/job-callback
# HMAC secret for verifying callback signatures (GW_CALLBACK_SECRET on the
# gateway side). SEPARATE from OPENAI_API_KEY — do not reuse the same value.
# Leave empty to skip signature verification (not recommended for prod).
LLM_GATEWAY_CALLBACK_SECRET=

# ---- App URL (baked into frontend build) ----
APP_URL=http://localhost:3000

# ---- DNS (for containers to resolve LAN hostnames like your LLM gateway) ----
# Set to your router/LAN DNS so container services can resolve local machine names.
# If your LLM gateway is on localhost (same machine), use host.docker.internal in OPENAI_API_BASE.
DNS_SERVER=192.168.1.1
