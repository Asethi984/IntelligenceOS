# =============================================================================
# IntelligenceOS Backend — Deployment Placeholder
# =============================================================================
# This file is COMMITTED to git with EMPTY values only. It exists so the
# Emergent platform's PullSource/build step can read the variable names.
#
# Real secret values are injected by the DEPLOYMENT ENVIRONMENT at runtime.
# python-dotenv (load_dotenv) never overwrites existing env vars, so the
# platform-injected values always take precedence over the empty values below.
#
# DO NOT put real secrets, keys, passwords, or connection strings in this file.
# For local development, copy backend/.env.example to backend/.env and fill in
# real values locally (the local copy is gitignored).
# =============================================================================

MONGO_URL=
DB_NAME=
JWT_SECRET=
CORS_ORIGINS=
OPENAI_API_KEY=
OPENAI_MODEL=
EMERGENT_LLM_KEY=
LLM_MODEL=
REDIS_URL=
RESEND_API_KEY=
RESEND_FROM=
APP_URL=
COOKIE_SECURE=true
COOKIE_SAMESITE=none
MAX_UPLOAD_BYTES=5242880
ALLOW_WEAK_JWT=
