# =============================================================================
# IntelligenceOS Backend — Deployment Placeholder
# =============================================================================
# COMMITTED to git with EMPTY/PLACEHOLDER values only. The Emergent platform
# reads this file during PullSource/build context prep.
#
# Real secret values are injected by the DEPLOYMENT ENVIRONMENT at runtime.
# python-dotenv (load_dotenv) never overwrites existing env vars, so the
# platform-injected values always take precedence over the values below.
#
# DO NOT put real secrets, keys, passwords, or connection strings in this file.
# For local dev, copy backend/.env.example to backend/.env and fill in real
# values locally (the local copy is gitignored).
# =============================================================================

MONGO_URL="mongodb://localhost:27017"
DB_NAME="test_database"
CORS_ORIGINS="*"
EMERGENT_LLM_KEY=
JWT_SECRET=
REDIS_URL=redis://localhost:6379/0
LLM_MODEL=gpt-5-nano
RESEND_API_KEY=
RESEND_FROM=IntelligenceOS <onboarding@resend.dev>
APP_URL=https://portfolio-intel-41.preview.emergentagent.com
