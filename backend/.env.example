# ---- Database ----
MONGO_URL="mongodb://user:password@host:27017/?authSource=admin"
DB_NAME="intelligenc_os_prod"

# ---- Security ----
# Generate with: python -c "import secrets;print(secrets.token_urlsafe(48))"
JWT_SECRET="replace-with-64-char-random-secret"
# Comma-separated explicit origins. NEVER use "*" with credentials.
CORS_ORIGINS="https://your-frontend.example.com"
# Cookie flags. Set COOKIE_SECURE=false only for local http dev.
COOKIE_SECURE=true
COOKIE_SAMESITE=none
# Max upload size in bytes (default 5 MB)
MAX_UPLOAD_BYTES=5242880
# Set to 1 only to bypass JWT strength check in local dev.
ALLOW_WEAK_JWT=

# ---- LLM / integrations ----
EMERGENT_LLM_KEY=sk-emergent-replace-me
LLM_MODEL=gpt-5.4

# ---- Email (Resend) ----
# Use your own verified domain; the shared onboarding@resend.dev is sandbox-only.
RESEND_API_KEY=re_replace_me
RESEND_FROM="IntelligenceOS <noreply@your-verified-domain.com>"

# ---- App ----
APP_URL=https://your-frontend.example.com

# ---- Cache (optional) ----
REDIS_URL=redis://localhost:6379/0
